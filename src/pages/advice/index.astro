---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import { articles } from "../../data/advice";
---

<BaseLayout
  title="Advice — Azar Fire"
  description="Plain-English passive fire protection advice — fire stopping, compartmentation surveys and compliance — for building owners, landlords and managers across the UK."
  path="/advice"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <Navbar />

  <main id="main">
    <!-- ── HERO ──────────────────────────────────────────────────────────── -->
    <section class="adv-hero" aria-labelledby="adv-hero-heading">
      <div class="container adv-hero-inner" data-reveal>
        <p class="eyebrow adv-hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Advice
        </p>
        <h1 id="adv-hero-heading" class="adv-hero-heading">
          Fire safety, simply explained.
        </h1>
        <p class="adv-hero-sub">
          Direct answers to the questions building owners, landlords and managers actually ask us.
          Surveys, fire doors, penetration sealing, proving you&rsquo;re covered.
        </p>
      </div>
    </section>

    <!-- ── ARTICLES ──────────────────────────────────────────────────────── -->
    <section class="adv-list" aria-labelledby="adv-list-heading">
      <div class="container">
        <header class="adv-list-header" data-reveal>
          <p class="script adv-list-label">Latest articles</p>
          <h2 id="adv-list-heading" class="adv-list-heading">
            Helping you understand what&rsquo;s needed, and why it matters.
          </h2>
        </header>

        <ul class="adv-grid">
          {articles.map((post, i) => (
            <li class="adv-card" data-reveal data-reveal-delay={`${(i % 3) * 90}ms`}>
              <a href={`/advice/${post.slug}`} class="adv-card-link">
                <div class="adv-card-media">
                  <Image
                    src={post.image}
                    alt={post.imageAlt}
                    widths={[400, 600, 800]}
                    sizes="(max-width: 767px) 100vw, 33vw"
                    loading="lazy"
                  />
                </div>
                <div class="adv-card-body">
                  <p class="adv-card-meta">
                    <span class="adv-card-cat">{post.category}</span>
                    <span class="adv-card-dot" aria-hidden="true">•</span>
                    <span class="adv-card-read">{post.readTime}</span>
                  </p>
                  <h3 class="adv-card-title">{post.title}</h3>
                  <p class="adv-card-excerpt">{post.excerpt}</p>
                  <span class="adv-card-cta" aria-hidden="true">Read article →</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────────────────────────── -->
    <section class="adv-cta-section">
      <div class="container">
        <div class="adv-cta" data-reveal>
          <h2 class="adv-cta-heading">Got a question about a building or a live project? Ask Azar.</h2>
          <a href="/#contact" class="btn btn-primary">Ask Azar Fire</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .skip-link {
    position: absolute;
    left: 0.75em;
    top: -3em;
    z-index: 100;
    padding: 0.6em 1.1em;
    background-color: var(--color-petrol);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    font-weight: 600;
    transition: top var(--transition-fast);
  }
  .skip-link:focus { top: 0.75em; }

  /* ── HERO ───────────────────────────────────────────────────────────── */
  .adv-hero {
    background-color: var(--color-petrol);
    color: var(--color-white);
  }
  .adv-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    padding-block: 5em 4.5em;
    max-width: 40em;
  }
  .adv-hero-eyebrow { color: var(--color-mustard); }
  .eyebrow-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background-color: var(--color-mustard);
  }
  .adv-hero-heading {
    font-size: clamp(2em, 4.4vw, 3em);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-white);
  }
  .adv-hero-sub {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.78);
  }

  /* ── ARTICLES ───────────────────────────────────────────────────────── */
  .adv-list {
    background-color: var(--color-white);
    padding-block: 6em;
  }
  .adv-list-header {
    max-width: 40em;
    margin-bottom: 3em;
  }
  .adv-list-label {
    font-size: 1.75em;
    margin-bottom: 0.2em;
  }
  .adv-list-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-petrol);
  }

  .adv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2em;
  }
  .adv-card {
    display: flex;
  }
  .adv-card-link {
    display: flex;
    flex-direction: column;
    background-color: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .adv-card-link:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .adv-card-media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background-color: var(--color-warm-white);
  }
  .adv-card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }
  .adv-card-link:hover .adv-card-media :global(img) { transform: scale(1.04); }

  .adv-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.625em;
    padding: 1.5em 1.5em 1.75em;
    flex: 1;
  }
  .adv-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--fs-sm);
  }
  .adv-card-cat {
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-mustard);
    font-size: var(--fs-xs);
  }
  .adv-card-dot { color: var(--color-grey-soft); }
  .adv-card-read { color: var(--color-grey-soft); font-size: var(--fs-xs); }
  .adv-card-title {
    font-size: var(--fs-lg);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-petrol);
  }
  .adv-card-excerpt {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
    flex: 1;
  }
  .adv-card-cta {
    margin-top: 0.25em;
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--color-petrol);
    transition: color var(--transition-fast);
  }
  .adv-card-link:hover .adv-card-cta { color: var(--color-mustard); }

  /* ── CTA ────────────────────────────────────────────────────────────── */
  .adv-cta-section {
    background-color: var(--color-warm-white);
    padding-block: 5em;
  }
  .adv-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2em;
    flex-wrap: wrap;
    background-color: var(--color-petrol);
    border-radius: var(--radius-lg);
    padding: 2.75em 3em;
  }
  .adv-cta-heading {
    font-size: var(--fs-xl);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-white);
    max-width: 18em;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────────────────── */
  @media (max-width: 991px) {
    .adv-list { padding-block: 4.5em; }
    .adv-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    .adv-hero-inner { padding-block: 3em 3em; }
    .adv-grid { grid-template-columns: 1fr; }
    .adv-list-heading { font-size: 2em; }
    .adv-cta { flex-direction: column; align-items: flex-start; padding: 2em; }
    .adv-cta .btn { width: 100%; }
  }
</style>
