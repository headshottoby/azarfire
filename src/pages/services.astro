---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import heroImg from "../assets/images/services-hero.jpg";

const instructedTo = [
  "Portfolio condition reviews",
  "Fire stopping and compartmentation inspections",
  "Remediation scope and contractor support",
  "Compliance reporting for duty holders",
];

const capabilities = [
  {
    title: "Passive fire surveys",
    body: "A structured review of compartmentation, fire stopping, service penetrations, fire doors and built-in protection measures.",
  },
  {
    title: "Fire stopping inspections",
    body: "Independent inspection of installed works with photographic evidence, location references and clear defect categorisation.",
  },
  {
    title: "Compartmentation reviews",
    body: "Assessment of walls, floors, risers, voids and interfaces where breaches can compromise the fire strategy.",
  },
  {
    title: "Remediation strategy",
    body: "Practical prioritisation and scope advice so project teams can move from findings to compliant works.",
  },
  {
    title: "Compliance reporting",
    body: "Clear reports for accountable persons, asset managers, project files and ongoing fire safety records.",
  },
  {
    title: "Portfolio support",
    body: "A consistent consultancy approach for multi-site estates, refurbishments, handovers and occupied buildings.",
  },
];
---

<BaseLayout
  title="Services — Azar Fire Ltd"
  description="Passive fire protection consultancy services across the UK, including surveys, inspections, reporting and remediation advice."
  path="/services"
>
  <a href="#main" class="skip-link">Skip to content</a>
  <Navbar />

  <main id="main">
    <!-- ── HERO ──────────────────────────────────────────────────────────── -->
    <section class="svc-hero" aria-labelledby="svc-hero-heading">
      <div class="svc-hero-photo" aria-hidden="true">
        <Image
          src={heroImg}
          alt=""
          widths={[760, 1200, 1920, 2400]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="svc-hero-veil" aria-hidden="true"></div>

      <div class="container svc-hero-inner">
        <div class="svc-hero-content" data-reveal>
          <p class="eyebrow svc-hero-eyebrow">
            <span class="eyebrow-dot" aria-hidden="true"></span>
            Services
          </p>
          <h1 id="svc-hero-heading" class="svc-hero-heading">
            Passive fire protection surveys, inspections and reporting — <em>evidence-led and FIRAS certified.</em>
          </h1>
          <p class="svc-hero-sub">
            Azar Fire works with building owners, managing agents, contractors and project teams to
            identify risk, evidence compliance and guide remediation — across portfolios and individual
            sites throughout the UK.
          </p>
          <div class="svc-hero-actions">
            <a href="/#contact" class="btn btn-primary">Discuss a project</a>
            <a href="/advice" class="btn btn-light">Read advice</a>
          </div>
        </div>

        <div class="svc-hero-card" data-reveal data-reveal-delay="120ms">
          <p class="svc-hero-card-title">We are typically instructed to</p>
          <ul class="svc-hero-card-list">
            {instructedTo.map((item) => (
              <li>
                <svg class="svc-check" viewBox="0 0 16 16" aria-hidden="true" fill="none">
                  <path d="M3.5 8.5l3 3 6-6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ── CORE CAPABILITIES ─────────────────────────────────────────────── -->
    <section class="svc-caps" aria-labelledby="svc-caps-heading">
      <div class="container">
        <header class="svc-caps-header" data-reveal>
          <p class="script svc-caps-label">Core capabilities</p>
          <h2 id="svc-caps-heading" class="svc-caps-heading">
            Specialist services for each stage of passive fire safety management.
          </h2>
        </header>

        <ul class="svc-caps-grid">
          {capabilities.map((cap, i) => (
            <li class="cap-card" data-reveal data-reveal-delay={`${(i % 3) * 90}ms`}>
              <span class="cap-index">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="cap-title">{cap.title}</h3>
              <p class="cap-body">{cap.body}</p>
              <span class="cap-line" aria-hidden="true"></span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────────────────────────── -->
    <section class="svc-cta-section">
      <div class="container">
        <div class="svc-cta" data-reveal>
          <div class="svc-cta-text">
            <h2 class="svc-cta-heading">Not sure which service you need?</h2>
            <p class="svc-cta-body">
              Share what you know about the building or project and we&rsquo;ll help scope the right
              route forward.
            </p>
          </div>
          <a href="/#contact" class="btn btn-primary svc-cta-btn">Contact Azar Fire</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .skip-link {
    position: absolute;
    left: 0.75em;
    top: -3em;
    z-index: 100;
    padding: 0.6em 1.1em;
    background-color: var(--color-petrol);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    font-weight: 600;
    transition: top var(--transition-fast);
  }
  .skip-link:focus { top: 0.75em; }

  /* ── HERO ───────────────────────────────────────────────────────────── */
  .svc-hero {
    position: relative;
    isolation: isolate;
    background-color: var(--color-petrol);
    color: var(--color-white);
    overflow: hidden;
  }
  .svc-hero-photo {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .svc-hero-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 70% center;
  }
  .svc-hero-veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, var(--color-petrol) 28%, rgba(0, 52, 77, 0.82) 50%, rgba(0, 52, 77, 0.4) 78%, rgba(0, 52, 77, 0.25) 100%),
      linear-gradient(0deg, var(--color-petrol) 4%, rgba(0, 52, 77, 0) 34%);
  }

  .svc-hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2.5em;
    padding-block: 5.5em 4em;
    min-height: 34em;
    justify-content: center;
  }
  .svc-hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    max-width: 40em;
  }
  .svc-hero-eyebrow { color: var(--color-mustard); }
  .eyebrow-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background-color: var(--color-mustard);
  }
  .svc-hero-heading {
    font-size: clamp(2em, 4.4vw, 3em);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-white);
    max-width: 16em;
  }
  .svc-hero-heading em {
    font-style: normal;
    color: var(--color-mustard);
  }
  .svc-hero-sub {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.78);
    max-width: 36em;
  }
  .svc-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875em;
    margin-top: 0.5em;
  }

  .svc-hero-card {
    max-width: 30em;
    padding: 1.5em 1.75em;
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-lg);
  }
  .svc-hero-card-title {
    font-size: var(--fs-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-mustard);
    margin-bottom: 1em;
  }
  .svc-hero-card-list {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }
  .svc-hero-card-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625em;
    font-size: var(--fs-base);
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
  }
  .svc-check {
    width: 1.05em;
    height: 1.05em;
    flex-shrink: 0;
    margin-top: 0.15em;
    color: var(--color-mustard);
  }

  /* ── CORE CAPABILITIES ──────────────────────────────────────────────── */
  .svc-caps {
    background-color: var(--color-white);
    padding-block: 6em;
  }
  .svc-caps-header {
    max-width: 40em;
    margin-bottom: 3em;
  }
  .svc-caps-label {
    font-size: 1.75em;
    margin-bottom: 0.2em;
  }
  .svc-caps-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-petrol);
  }
  .svc-caps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }
  .cap-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.625em;
    padding: 2em 1.875em 2.25em;
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base),
      background-color var(--transition-base);
  }
  .cap-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    background-color: var(--color-white);
  }
  .cap-index {
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-mustard);
  }
  .cap-title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-petrol);
    line-height: 1.2;
  }
  .cap-body {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
  }
  .cap-line {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 3px;
    width: 100%;
    background-color: var(--color-mustard);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
  }
  .cap-card:hover .cap-line { transform: scaleX(1); }

  /* ── CTA ────────────────────────────────────────────────────────────── */
  .svc-cta-section {
    background-color: var(--color-warm-white);
    padding-block: 5em;
  }
  .svc-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5em;
    flex-wrap: wrap;
    background-color: var(--color-petrol);
    border-radius: var(--radius-lg);
    padding: 3em;
    color: var(--color-white);
  }
  .svc-cta-heading {
    font-size: var(--fs-xl);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-white);
    margin-bottom: 0.5em;
  }
  .svc-cta-body {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.78);
    max-width: 34em;
  }
  .svc-cta-btn { flex-shrink: 0; }

  /* ── RESPONSIVE ─────────────────────────────────────────────────────── */
  @media (max-width: 991px) {
    .svc-hero-photo :global(img) { object-position: 64% center; }
    .svc-hero-veil {
      background:
        linear-gradient(180deg, rgba(0, 52, 77, 0.5) 0%, rgba(0, 52, 77, 0.66) 48%, rgba(0, 52, 77, 0.9) 100%);
    }
    .svc-hero-inner { padding-block: 4em 3.5em; min-height: 0; }
    .svc-caps { padding-block: 4.5em; }
    .svc-caps-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 767px) {
    .svc-hero-heading { font-size: 2.25em; }
    .svc-hero-actions { width: 100%; }
    .svc-hero-actions .btn { flex: 1 1 auto; }
    .svc-caps-grid { grid-template-columns: 1fr; }
    .svc-caps-heading { font-size: 2em; }
    .svc-cta { padding: 2em; flex-direction: column; align-items: flex-start; }
    .svc-cta-btn { width: 100%; }
  }
</style>
