---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import TrustBar from "../components/TrustBar.astro";
import Process from "../components/Process.astro";
import WhyAzar from "../components/WhyAzar.astro";
import PassiveFireProtection from "../components/PassiveFireProtection.astro";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Azar Fire — Nationwide Fire Safety Services"
  description="Fire safety consultancy and passive fire protection for businesses and landlords across the UK."
>
  <Navbar />
  <main>
    <Hero />
    <Services />
    <TrustBar />
    <Process />
    <WhyAzar />
    <PassiveFireProtection />
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
