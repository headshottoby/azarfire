---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import type { Article } from "../data/advice";

interface Props {
  article: Article;
}

const { article } = Astro.props;
const siteUrl = "https://azarfire.co.uk";
const url = `${siteUrl}/advice/${article.slug}`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: article.title,
      description: article.excerpt,
      datePublished: article.date,
      author: { "@type": "Organization", name: "Azar Fire Ltd", url: siteUrl },
      publisher: {
        "@type": "Organization",
        name: "Azar Fire Ltd",
        url: siteUrl,
        logo: { "@type": "ImageObject", url: `${siteUrl}/assets/images/logo-azar.png` },
      },
      mainEntityOfPage: url,
      articleSection: article.category,
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Advice", item: `${siteUrl}/advice` },
        { "@type": "ListItem", position: 3, name: article.title, item: url },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${article.title} — Azar Fire Ltd`}
  description={article.excerpt}
  path={`/advice/${article.slug}`}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={article.date} />
    <meta property="article:section" content={article.category} />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <a href="#main" class="skip-link">Skip to content</a>
  <Navbar />

  <main id="main">
    <article class="post">
      <!-- HEADER -->
      <header class="post-header">
        <div class="container post-header-inner">
          <nav class="post-crumbs" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">/</span>
            <a href="/advice">Advice</a>
            <span aria-hidden="true">/</span>
            <span class="post-crumbs-current">{article.category}</span>
          </nav>
          <p class="post-cat">{article.category}</p>
          <h1 class="post-title">{article.title}</h1>
          <p class="post-meta">
            <time datetime={article.date}>{article.dateLabel}</time>
            <span aria-hidden="true">•</span>
            <span>{article.readTime}</span>
            <span aria-hidden="true">•</span>
            <span>Azar Fire</span>
          </p>
        </div>
      </header>

      <!-- HERO IMAGE -->
      <div class="container">
        <div class="post-hero-media">
          <Image
            src={article.image}
            alt={article.imageAlt}
            widths={[760, 1200, 1600]}
            sizes="(max-width: 991px) 100vw, 60em"
            loading="eager"
          />
        </div>
      </div>

      <!-- BODY -->
      <div class="container">
        <div class="post-body prose">
          <slot />
        </div>

        <aside class="post-cta">
          <div>
            <h2 class="post-cta-heading">Need advice about a live building or project?</h2>
            <p class="post-cta-sub">
              Tell us what you know and we&rsquo;ll help scope the right route forward — with no
              jargon and no pressure.
            </p>
          </div>
          <a href="/#contact" class="btn btn-primary">Ask Azar Fire</a>
        </aside>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .skip-link {
    position: absolute;
    left: 0.75em;
    top: -3em;
    z-index: 100;
    padding: 0.6em 1.1em;
    background-color: var(--color-petrol);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    font-weight: 600;
    transition: top var(--transition-fast);
  }
  .skip-link:focus { top: 0.75em; }

  .post { background-color: var(--color-warm-white); }

  /* HEADER */
  .post-header {
    background-color: var(--color-petrol);
    color: var(--color-white);
  }
  .post-header-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75em;
    padding-block: 3.5em 3em;
    max-width: 52em;
  }
  .post-crumbs {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.6);
  }
  .post-crumbs a {
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--transition-fast);
  }
  .post-crumbs a:hover { color: var(--color-mustard); }
  .post-crumbs-current { color: rgba(255, 255, 255, 0.85); }

  .post-cat {
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-mustard);
  }
  .post-title {
    font-size: clamp(1.875em, 4vw, 2.75em);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-white);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.6em;
    flex-wrap: wrap;
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.7);
  }
  .post-meta span[aria-hidden] { color: rgba(255, 255, 255, 0.4); }

  /* HERO IMAGE */
  .post-hero-media {
    max-width: 60em;
    margin-inline: auto;
    margin-top: -2.5em;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 16 / 9;
  }
  .post-hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* BODY / PROSE */
  .post-body {
    max-width: 44em;
    margin-inline: auto;
    padding-block: 3.25em 1em;
  }
  .prose :global(p) {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-charcoal);
    margin-bottom: 1.25em;
  }
  .prose :global(.lead) {
    font-size: var(--fs-lg);
    line-height: 1.5;
    color: var(--color-petrol);
    font-weight: 500;
    margin-bottom: 1.5em;
  }
  .prose :global(h2) {
    font-size: var(--fs-xl);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-petrol);
    letter-spacing: -0.02em;
    margin-top: 1.6em;
    margin-bottom: 0.5em;
  }
  .prose :global(h3) {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-petrol);
    margin-top: 1.4em;
    margin-bottom: 0.4em;
  }
  .prose :global(ul) {
    margin: 0 0 1.25em 0;
    padding-left: 1.25em;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }
  .prose :global(li) {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-charcoal);
    padding-left: 0.35em;
  }
  .prose :global(li)::marker { color: var(--color-mustard); }
  .prose :global(strong) { color: var(--color-petrol); font-weight: 700; }
  .prose :global(a) {
    color: var(--color-petrol);
    text-decoration: underline;
    text-decoration-color: var(--color-mustard);
    text-underline-offset: 2px;
  }
  .prose :global(blockquote) {
    margin: 1.5em 0;
    padding: 0.25em 0 0.25em 1.25em;
    border-left: 3px solid var(--color-mustard);
    color: var(--color-petrol);
    font-size: var(--fs-md);
  }

  /* CTA */
  .post-cta {
    max-width: 44em;
    margin: 1.5em auto 0;
    margin-bottom: 5em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2em;
    flex-wrap: wrap;
    background-color: var(--color-petrol);
    color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: 2.25em 2.5em;
  }
  .post-cta-heading {
    font-size: var(--fs-lg);
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-white);
    margin-bottom: 0.4em;
    max-width: 16em;
  }
  .post-cta-sub {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.78);
    max-width: 28em;
  }

  @media (max-width: 767px) {
    .post-hero-media { aspect-ratio: 3 / 2; margin-top: -1.5em; }
    .post-body { padding-block: 2.5em 1em; }
    .post-cta { flex-direction: column; align-items: flex-start; padding: 1.75em; margin-bottom: 3.5em; }
    .post-cta .btn { width: 100%; }
  }
</style>
