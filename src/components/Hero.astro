---
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-image" aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow">Nationwide Fire Services</p>
      <h1 id="hero-heading" class="hero-heading">
        Protecting <span class="hero-people">the people and places</span> you&rsquo;re responsible for
      </h1>
      <p class="hero-sub">
        Fire safety consultancy and passive fire protection for businesses and landlords across the UK
      </p>
      <div class="hero-buttons">
        <a href="/contact" class="btn btn-primary">Get in touch</a>
        <a href="/services" class="btn btn-outline">See our services</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-petrol);
    color: var(--color-warm-white);
    overflow: hidden;
    min-height: 36.5625em; /* 585px */
  }

  .hero-image {
    position: absolute;
    inset: 0;
    background-image: url("/assets/images/hero-fire-services.jpg");
    background-size: cover;
    background-position: center right;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(270deg, rgba(255, 255, 255, 0) 0%, rgba(0, 52, 77, 1) 100%),
      linear-gradient(179.7deg, rgba(255, 255, 255, 0) 27.7%, rgba(0, 52, 77, 0.9) 102.9%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: 6.5em 5em; /* 104px top */
    min-height: 36.5625em;
    display: flex;
    align-items: flex-start;
  }

  .hero-content {
    max-width: 41.875em; /* 670px */
    display: flex;
    flex-direction: column;
    gap: 2.5em;
  }

  .hero-eyebrow {
    font-family: var(--font-accent);
    font-size: 1.125em; /* 18px */
    line-height: 1.667;
    color: var(--color-warm-white);
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--fs-3xl); /* 52px */
    line-height: 1.1;
    color: var(--color-mustard);
    margin: 0;
  }

  .hero-people {
    font-style: italic;
    color: var(--color-white);
  }

  .hero-sub {
    font-family: var(--font-heading);
    font-size: var(--fs-md); /* 20px */
    line-height: 1.4;
    color: var(--color-warm-white);
    max-width: 33.9375em; /* 543px */
  }

  .hero-buttons {
    display: flex;
    gap: 1.5625em; /* 25px */
    flex-wrap: wrap;
    margin-top: 0.5em;
  }

  @media (max-width: 991px) {
    .hero-heading {
      font-size: 2.625em; /* ~42px */
    }
    .hero-inner {
      padding-block: 4em;
    }
    .hero {
      min-height: 30em;
    }
  }

  @media (max-width: 767px) {
    .hero-heading {
      font-size: 2.125em; /* ~34px */
    }
    .hero-content {
      gap: 1.5em;
    }
    .hero-image {
      background-position: center;
    }
    .hero-overlay {
      background-image:
        linear-gradient(0deg, rgba(0, 52, 77, 0.85) 0%, rgba(0, 52, 77, 0.7) 100%);
    }
  }
</style>
