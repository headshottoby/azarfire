---
import { Image } from "astro:assets";
import heroImg from "../assets/images/hero-fire-door.jpg";

const badges = [
  "FIRAS Certified",
  "UK Nationwide",
  "All building types",
];
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-photo" aria-hidden="true">
    <Image
      src={heroImg}
      alt=""
      widths={[760, 1200, 1920, 2400]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="hero-veil" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <h1 id="hero-heading" class="hero-heading">Passive Fire Protection.<br /><em>Built Right.</em></h1>
      <p class="hero-sub">
        Most buildings rely on fire protection that&rsquo;s never been checked. Azar Fire surveys,
        fixes and certifies the parts that actually stop fire spreading. We tell you exactly what
        state it&rsquo;s in, and what needs doing.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Speak with us</a>
        <a href="/services" class="btn btn-light">What we offer</a>
      </div>
    </div>

    <ul class="hero-badges">
      {badges.map((badge) => (
        <li class="hero-badge">
          <svg class="hero-badge-icon" viewBox="0 0 16 16" aria-hidden="true" fill="none">
            <path d="M3.5 8.5l3 3 6-6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          {badge}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    background-color: var(--color-petrol);
    color: var(--color-white);
    overflow: hidden;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 24% 46%;
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, var(--color-petrol) 26%, rgba(0, 52, 77, 0.82) 46%, rgba(0, 52, 77, 0.45) 70%, rgba(0, 52, 77, 0.32) 100%),
      linear-gradient(0deg, var(--color-petrol) 4%, rgba(0, 52, 77, 0) 32%);
  }

  .hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 3.5em;
    padding-block: 6em 3.25em;
    min-height: 38em;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5em;
    max-width: 38em;
  }

  .hero-eyebrow {
    color: var(--color-mustard);
  }
  .eyebrow-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background-color: var(--color-mustard);
  }

  .hero-heading {
    font-size: var(--fs-3xl);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--color-white);
  }
  .hero-heading em {
    font-style: normal;
    color: var(--color-mustard);
  }

  .hero-sub {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.78);
    max-width: 34em;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875em;
    margin-top: 0.5em;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75em;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.6em 1em;
    font-size: var(--fs-sm);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
  }
  .hero-badge-icon {
    width: 1em;
    height: 1em;
    color: var(--color-mustard);
    flex-shrink: 0;
  }

  @media (max-width: 991px) {
    .hero-photo { inset: 0; }
    .hero-veil {
      background:
        linear-gradient(180deg, rgba(0, 52, 77, 0.5) 0%, rgba(0, 52, 77, 0.64) 48%, rgba(0, 52, 77, 0.88) 100%);
    }
    .hero-inner {
      padding-block: 4em 3em;
      min-height: 0;
      gap: 3em;
    }
  }

  @media (max-width: 767px) {
    .hero-heading { font-size: 2.5em; }
    .hero-inner { padding-block: 3em 2.5em; }
    .hero-actions { width: 100%; }
    .hero-actions .btn { flex: 1 1 auto; }
  }
</style>
