---
import { Image } from "astro:assets";
import methodImg from "../assets/images/method-survey-app.jpg";

const steps = [
  {
    number: "01",
    title: "Talk it through",
    body: "We find out what type of building you have and what you need.",
  },
  {
    number: "02",
    title: "Check the building (passive fire survey)",
    body: "If needed, we go through your building for gaps, damaged doors and weak spots, and show you exactly where they are with photos and a clear to-do list.",
  },
  {
    number: "03",
    title: "Do the work",
    body: "Our trained team carries out the repairs using approved materials.",
  },
  {
    number: "04",
    title: "Hand you the proof",
    body: "You get full certification and a complete record of everything we did. Proof of compliance, ready whenever you need it.",
  },
];
---

<section class="process" aria-labelledby="process-heading">
  <div class="container">
    <header class="process-header" data-reveal>
      <p class="eyebrow process-eyebrow">Method</p>
      <p class="script process-label">Our process</p>
      <h2 id="process-heading" class="process-heading">
        A straightforward, four-step process.
      </h2>
      <p class="process-intro">
        You don&rsquo;t need to understand fire engineering, that&rsquo;s our job. Here&rsquo;s
        exactly what happens at each stage, and what you&rsquo;ll have at the end of it.
      </p>
    </header>

    <div class="process-banner" data-reveal>
      <Image
        src={methodImg}
        alt="Azar Fire engineer logging a fire door survey on the job-tracking app"
        widths={[640, 1000, 1600]}
        sizes="(max-width: 991px) 100vw, 90vw"
        loading="lazy"
      />
    </div>

    <ol class="process-steps">
      {steps.map((step, i) => (
        <li class="process-step" data-reveal data-reveal-delay={`${i * 110}ms`}>
          <span class="process-number">{step.number}</span>
          <span class="process-node" aria-hidden="true"></span>
          <h3 class="process-step-title">{step.title}</h3>
          <p class="process-step-body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process {
    background-color: var(--color-petrol);
    color: var(--color-white);
    padding-block: 6em;
  }

  .process-header {
    max-width: 44em;
    margin-bottom: 2.5em;
  }

  .process-banner {
    width: 100%;
    aspect-ratio: 2.4 / 1;
    margin-bottom: 3.5em;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-line-light);
  }
  .process-banner :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 34%;
  }
  .process-eyebrow {
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 0.5em;
  }
  .process-label {
    font-size: 1.75em;
    margin-bottom: 0.2em;
  }
  .process-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-white);
    margin-bottom: 0.6em;
  }
  .process-intro {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.72);
    max-width: 40em;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2em;
  }

  .process-step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    padding-top: 2.75em;
  }
  /* connector line behind the nodes */
  .process-step::before {
    content: "";
    position: absolute;
    top: 0.6875em;
    left: 0;
    right: -2em;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.18);
  }
  .process-step:last-child::before { right: 0; }

  .process-node {
    position: absolute;
    top: 0.3125em;
    left: 0;
    width: 0.75em;
    height: 0.75em;
    border-radius: 50%;
    background-color: var(--color-mustard);
    box-shadow: 0 0 0 4px rgba(217, 166, 41, 0.18);
  }

  .process-number {
    font-size: var(--fs-xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-mustard);
    line-height: 1;
  }
  .process-step-title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.2;
  }
  .process-step-body {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 991px) {
    .process { padding-block: 4.5em; }
    .process-steps { grid-template-columns: repeat(2, 1fr); gap: 2.5em 2em; }
    .process-heading { font-size: 2.25em; }
  }

  @media (max-width: 767px) {
    .process-steps { grid-template-columns: 1fr; gap: 2em; }
    .process-heading { font-size: 2em; }
    .process-banner { aspect-ratio: 16 / 11; }
    .process-step { padding-top: 0; padding-left: 1.75em; }
    .process-step::before {
      top: 0; bottom: 0; left: 0.3125em; right: auto;
      width: 1px; height: auto;
    }
    .process-step:last-child::before { bottom: 50%; }
    .process-node { top: 0.4em; left: 0; }
  }
</style>
