---
import { Image } from "astro:assets";
import pfpImg from "../assets/images/pfp-firestopping.jpg";

const benefits = [
  "Limits the spread of fire, heat, and smoke by containing it at source.",
  "Protects escape routes and allows vital time for safe evacuation.",
  "Safeguards the building structure and assets, supporting long-term sustainability.",
  "A clear, auditable compliance trail from survey through to certification.",
];
---

<section class="pfp" id="advice" aria-labelledby="pfp-heading">
  <div class="container pfp-inner">
    <div class="pfp-media" data-reveal>
      <Image
        src={pfpImg}
        alt="Azar Fire operative applying fire-stopping sealant around a structural steel penetration"
        widths={[520, 760, 1040]}
        sizes="(max-width: 991px) 100vw, 42vw"
        loading="lazy"
      />
    </div>

    <div class="pfp-content" data-reveal data-reveal-delay="100ms">
      <p class="script pfp-label">Advice</p>
      <h2 id="pfp-heading" class="pfp-heading">What is passive fire protection?</h2>

      <p class="pfp-body">
        Passive fire protection — also known as built fire protection — is the fire safety fabric
        built into a building itself. It works by dividing structures into compartments that restrict
        the growth and spread of fire, protecting escape routes, preserving structural integrity, and
        buying critical time for occupants to evacuate and firefighters to work safely. Unlike
        sprinklers or extinguishers, it requires no activation — it is always working.
      </p>
      <p class="pfp-body">
        As a building owner or manager, compliance is your legal responsibility. When passive fire
        measures are missing, damaged or poorly installed, buildings carry hidden risk. A clear survey
        — and certified remediation — puts you back in control.
      </p>

      <p class="pfp-subhead">What good passive fire protection delivers</p>
      <ul class="pfp-benefits">
        {benefits.map((benefit) => (
          <li class="pfp-benefit">
            <svg class="pfp-benefit-icon" viewBox="0 0 20 20" aria-hidden="true" fill="none">
              <circle cx="10" cy="10" r="10" fill="currentColor" opacity="0.14" />
              <path d="M5.5 10.2l3 3 6-6.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{benefit}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .pfp {
    background-color: var(--color-warm-white);
    padding-block: 6em;
  }

  .pfp-inner {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 4em;
    align-items: center;
  }

  .pfp-media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .pfp-media :global(img) {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .pfp-content {
    display: flex;
    flex-direction: column;
  }
  .pfp-label {
    font-size: 1.75em;
    margin-bottom: 0.15em;
  }
  .pfp-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-petrol);
    margin-bottom: 0.7em;
  }
  .pfp-body {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
    margin-bottom: 1em;
  }

  .pfp-subhead {
    font-size: var(--fs-md);
    font-weight: 700;
    color: var(--color-petrol);
    margin-top: 0.75em;
    margin-bottom: 1em;
  }
  .pfp-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.875em;
  }
  .pfp-benefit {
    display: flex;
    align-items: flex-start;
    gap: 0.75em;
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-charcoal);
  }
  .pfp-benefit-icon {
    width: 1.375em;
    height: 1.375em;
    flex-shrink: 0;
    margin-top: 0.1em;
    color: var(--color-mustard);
  }

  @media (max-width: 991px) {
    .pfp { padding-block: 4.5em; }
    .pfp-inner { grid-template-columns: 1fr; gap: 2.5em; }
    .pfp-media { max-width: 30em; }
    .pfp-media :global(img) { aspect-ratio: 16 / 11; }
    .pfp-heading { font-size: 2.25em; }
  }

  @media (max-width: 767px) {
    .pfp-heading { font-size: 2em; }
  }
</style>
