---
import { Image } from "astro:assets";
import pfpImg from "../assets/images/pfp-firestopping.jpg";

const benefits = [
  "Stops a fire in one room or flat from spreading to the rest of the building.",
  "Keeps escape routes clear of smoke and flames, so people get out safely.",
  "Protects the building itself, so it can be repaired rather than rebuilt.",
  "Gives you paperwork that proves you've done the right thing ready for insurers, assessors or inspections.",
];
---

<section class="pfp" id="advice" aria-labelledby="pfp-heading">
  <div class="container pfp-inner">
    <div class="pfp-media" data-reveal>
      <Image
        src={pfpImg}
        alt="Azar Fire operative applying fire-stopping sealant around a structural steel penetration"
        widths={[520, 760, 1040]}
        sizes="(max-width: 991px) 100vw, 42vw"
        loading="lazy"
      />
    </div>

    <div class="pfp-content" data-reveal data-reveal-delay="100ms">
      <p class="script pfp-label">Advice</p>
      <h2 id="pfp-heading" class="pfp-heading">What&rsquo;s actually stopping fire from spreading through your building?</h2>

      <p class="pfp-body">
        Most of what keeps a fire contained isn&rsquo;t an alarm or a sprinkler, it&rsquo;s the
        building itself. Properly sealed walls, doors that actually close and latch, pipework gaps
        filled in rather than left open. None of it needs switching on. It just has to be there,
        intact.
      </p>
      <p class="pfp-body">
        If you own or manage a building, you&rsquo;re legally responsible for this, whether you put
        it there or inherited it from someone else. You usually can&rsquo;t tell it&rsquo;s missing
        or damaged just by looking. A survey tells you exactly where you stand.
      </p>

      <p class="pfp-subhead">What this actually means for you</p>
      <ul class="pfp-benefits">
        {benefits.map((benefit) => (
          <li class="pfp-benefit">
            <svg class="pfp-benefit-icon" viewBox="0 0 20 20" aria-hidden="true" fill="none">
              <circle cx="10" cy="10" r="10" fill="currentColor" opacity="0.14" />
              <path d="M5.5 10.2l3 3 6-6.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>{benefit}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .pfp {
    background-color: var(--color-warm-white);
    padding-block: 6em;
  }

  .pfp-inner {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 4em;
    align-items: center;
  }

  .pfp-media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .pfp-media :global(img) {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .pfp-content {
    display: flex;
    flex-direction: column;
  }
  .pfp-label {
    font-size: 1.75em;
    margin-bottom: 0.15em;
  }
  .pfp-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-petrol);
    margin-bottom: 0.7em;
  }
  .pfp-body {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
    margin-bottom: 1em;
  }

  .pfp-subhead {
    font-size: var(--fs-md);
    font-weight: 700;
    color: var(--color-petrol);
    margin-top: 0.75em;
    margin-bottom: 1em;
  }
  .pfp-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.875em;
  }
  .pfp-benefit {
    display: flex;
    align-items: flex-start;
    gap: 0.75em;
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-charcoal);
  }
  .pfp-benefit-icon {
    width: 1.375em;
    height: 1.375em;
    flex-shrink: 0;
    margin-top: 0.1em;
    color: var(--color-mustard);
  }

  @media (max-width: 991px) {
    .pfp { padding-block: 4.5em; }
    .pfp-inner { grid-template-columns: 1fr; gap: 2.5em; }
    .pfp-media { max-width: 30em; }
    .pfp-media :global(img) { aspect-ratio: 16 / 11; }
    .pfp-heading { font-size: 2.25em; }
  }

  @media (max-width: 767px) {
    .pfp-heading { font-size: 2em; }
  }
</style>
