---
---

<section class="trust-bar" aria-labelledby="trust-heading">
  <div class="container trust-bar-inner">
    <header class="trust-bar-header">
      <p class="trust-bar-eyebrow">Affordable fire safety solutions</p>
      <h2 id="trust-heading" class="trust-bar-heading">Meet Our Clients</h2>
    </header>

    <ul class="trust-bar-logos" aria-label="Client logos">
      {[0, 1, 2, 3].map(() => (
        <li class="trust-bar-logo">
          <img src="/assets/images/client-logo-placeholder.svg" alt="" aria-hidden="true" />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust-bar {
    background-color: var(--color-charcoal);
    color: var(--color-white);
    padding-block: 3em 4em;
  }

  .trust-bar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3em;
  }

  .trust-bar-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5em;
  }

  .trust-bar-eyebrow {
    font-family: var(--font-accent);
    font-size: var(--fs-sm); /* 16px */
    color: var(--color-warm-white);
    opacity: 0.7;
    line-height: 1.2;
  }

  .trust-bar-heading {
    font-family: var(--font-accent);
    font-weight: 600;
    font-size: 2.75em; /* 44px */
    line-height: 1.2;
    color: var(--color-white);
  }

  .trust-bar-logos {
    display: grid;
    grid-template-columns: repeat(4, 8.8125em); /* 141px each */
    gap: 2.0625em; /* 33px */
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .trust-bar-logo {
    width: 8.8125em; /* 141px */
    height: 8.625em; /* 138px */
    border: 1px solid var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .trust-bar-logo img {
    width: 75%;
    height: 75%;
    object-fit: contain;
    opacity: 0.55;
  }

  @media (max-width: 991px) {
    .trust-bar-logos {
      grid-template-columns: repeat(4, 6em);
      gap: 1em;
    }
    .trust-bar-logo {
      width: 6em;
      height: 6em;
    }
  }

  @media (max-width: 767px) {
    .trust-bar-heading {
      font-size: 2em;
    }
    .trust-bar-logos {
      grid-template-columns: repeat(2, 6em);
    }
  }
</style>
