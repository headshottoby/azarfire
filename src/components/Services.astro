---
import { Image } from "astro:assets";
import teamImg from "../assets/images/team-doorway.jpg";

const services = [
  {
    title: "Passive fire surveys",
    body: "Building-wide reviews of compartmentation, service penetrations, doorsets and fire-resisting construction.",
  },
  {
    title: "Fire stopping inspections",
    body: "Independent inspections of installed systems with evidence-led findings and practical next steps.",
  },
  {
    title: "Compartmentation reviews",
    body: "Assessment of fire-resisting lines, breaches and defects that could compromise compartment strategy.",
  },
  {
    title: "Remediation advice",
    body: "Clear scopes and prioritised recommendations to support competent contractors and accountable teams.",
  },
  {
    title: "Compliance reporting",
    body: "Concise reports designed for duty holders, asset managers, project teams and fire safety records.",
  },
  {
    title: "Nationwide consultancy",
    body: "Support across the UK for portfolios, refurbishments, construction handovers and occupied sites.",
  },
];
---

<section class="services" id="services" aria-labelledby="services-heading">
  <div class="container">
    <header class="services-header" data-reveal>
      <p class="script services-label">Core services</p>
      <h2 id="services-heading" class="services-heading">
        Expert passive fire protection for every building type.
      </h2>
      <p class="services-intro">
        Passive fire protection is not a box-ticking exercise. Every installation we undertake is
        specified to the building, carried out by trained operatives, and fully FIRAS-certified.
        Here&rsquo;s how we can help.
      </p>
    </header>

    <div class="services-banner" data-reveal>
      <Image
        src={teamImg}
        alt="Azar Fire operatives on site at a fire door"
        widths={[760, 1200, 1920, 2400]}
        sizes="(max-width: 991px) 100vw, 90vw"
        loading="lazy"
      />
    </div>

    <ul class="services-grid">
      {services.map((service, i) => (
        <li class="service-card" data-reveal data-reveal-delay={`${(i % 3) * 90}ms`}>
          <span class="service-index">{String(i + 1).padStart(2, "0")}</span>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-body">{service.body}</p>
          <span class="service-line" aria-hidden="true"></span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-white);
    padding-block: 6em;
  }

  .services-header {
    max-width: 44em;
    margin-bottom: 2.5em;
  }

  .services-banner {
    width: 100%;
    aspect-ratio: 2.5 / 1;
    margin-bottom: 3.5em;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .services-banner :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
  }
  .services-label {
    font-size: 1.75em;
    margin-bottom: 0.2em;
  }
  .services-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-petrol);
    margin-bottom: 0.6em;
  }
  .services-intro {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
    max-width: 38em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.625em;
    padding: 2em 1.875em 2.25em;
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base),
      background-color var(--transition-base);
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    background-color: var(--color-white);
  }

  .service-index {
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-mustard);
  }
  .service-title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-petrol);
    line-height: 1.2;
  }
  .service-body {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
  }
  .service-line {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 3px;
    width: 100%;
    background-color: var(--color-mustard);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
  }
  .service-card:hover .service-line { transform: scaleX(1); }

  @media (max-width: 991px) {
    .services { padding-block: 4.5em; }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 767px) {
    .services-grid { grid-template-columns: 1fr; }
    .services-heading { font-size: 2em; }
    .services-banner { aspect-ratio: 3 / 2; }
  }
</style>
