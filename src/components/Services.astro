---
import { Image } from "astro:assets";
import teamImg from "../assets/images/team-doorway.jpg";

const services = [
  {
    title: "Passive Fire Surveys",
    body: "We check your building and tell you, in plain terms, exactly what's missing or damaged so you know your risk before anyone else points it out.",
  },
  {
    title: "Fire Stopping Inspections",
    body: "Had fire-stopping installed by someone else? We inspect it independently and tell you honestly whether it's actually safe, with photos to back it up.",
  },
  {
    title: "Compartmentation Review",
    body: "Walls and floors are meant to stop fire spreading between rooms or flats. We find the gaps that let it through, before they become a problem.",
  },
  {
    title: "Remediation Advice",
    body: "No vague reports. We tell you exactly what needs doing, in what order, so you can brief a contractor with confidence and control costs.",
  },
  {
    title: "Compliance Reporting",
    body: "Clear, simple reports you can hand to your insurer, your fire risk assessor, or a regulator, proving the building is looked after.",
  },
  {
    title: "Nationwide Coverage",
    body: "Managing several buildings or a whole portfolio? We work the same way everywhere, so you get consistent, comparable results across every site.",
  },
];
---

<section class="services" id="services" aria-labelledby="services-heading">
  <div class="container">
    <header class="services-header" data-reveal>
      <p class="script services-label">Core services</p>
      <h2 id="services-heading" class="services-heading">
        Whatever your building, we can guide you towards the right fire stopping and compartmentation work.
      </h2>
      <p class="services-intro">
        You can&rsquo;t tell just by looking whether a building is properly protected against fire
        spreading. Most passive fire protection work, such as fire stopping and compartmentation, is
        hidden inside walls, ceilings and doors. We check it, fix it, and give you the paperwork to
        prove it. Here&rsquo;s how we help.
      </p>
    </header>

    <div class="services-banner" data-reveal>
      <Image
        src={teamImg}
        alt="Azar Fire operatives on site at a fire door"
        widths={[760, 1200, 1920, 2400]}
        sizes="(max-width: 991px) 100vw, 90vw"
        loading="lazy"
      />
    </div>

    <ul class="services-grid">
      {services.map((service, i) => (
        <li class="service-card" data-reveal data-reveal-delay={`${(i % 3) * 90}ms`}>
          <span class="service-index">{String(i + 1).padStart(2, "0")}</span>
          <h3 class="service-title">{service.title}</h3>
          <p class="service-body">{service.body}</p>
          <span class="service-line" aria-hidden="true"></span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-white);
    padding-block: 6em;
  }

  .services-header {
    max-width: 44em;
    margin-bottom: 2.5em;
  }

  .services-banner {
    width: 100%;
    aspect-ratio: 2.5 / 1;
    margin-bottom: 3.5em;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .services-banner :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
  }
  .services-label {
    font-size: 1.75em;
    margin-bottom: 0.2em;
  }
  .services-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-petrol);
    margin-bottom: 0.6em;
  }
  .services-intro {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
    max-width: 38em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
  }

  .service-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.625em;
    padding: 2em 1.875em 2.25em;
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base),
      background-color var(--transition-base);
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    background-color: var(--color-white);
  }

  .service-index {
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-mustard);
  }
  .service-title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-petrol);
    line-height: 1.2;
  }
  .service-body {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
  }
  .service-line {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 3px;
    width: 100%;
    background-color: var(--color-mustard);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
  }
  .service-card:hover .service-line { transform: scaleX(1); }

  @media (max-width: 991px) {
    .services { padding-block: 4.5em; }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 767px) {
    .services-grid { grid-template-columns: 1fr; }
    .services-heading { font-size: 2em; }
    .services-banner { aspect-ratio: 3 / 2; }
  }
</style>
