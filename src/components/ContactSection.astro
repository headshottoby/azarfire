---
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="container contact-inner">
    <div class="contact-info" data-reveal>
      <p class="script contact-label">Contact</p>
      <h2 id="contact-heading" class="contact-heading">
        Get in touch. It&rsquo;s the simplest way to find out where you stand.
      </h2>
      <p class="contact-intro">
        Tell us about your building or project. We&rsquo;ll tell you straight what&rsquo;s involved
        and what it&rsquo;d take to get you covered.
      </p>

      <ul class="contact-details">
        <li>
          <a href="mailto:info@azarfire.co.uk" class="contact-detail">
            <span class="contact-detail-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M3 6.5A1.5 1.5 0 014.5 5h15A1.5 1.5 0 0121 6.5v11a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 17.5v-11z" stroke="currentColor" stroke-width="1.6"/><path d="M4 7l8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="contact-detail-text">
              <span class="contact-detail-label">Email</span>
              <span class="contact-detail-value">info@azarfire.co.uk</span>
            </span>
          </a>
        </li>
        <li>
          <a href="tel:+441522530048" class="contact-detail">
            <span class="contact-detail-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M6.5 3.5h3l1.5 4-2 1.5a12 12 0 005.5 5.5l1.5-2 4 1.5v3a2 2 0 01-2 2A16 16 0 014.5 5.5a2 2 0 012-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </span>
            <span class="contact-detail-text">
              <span class="contact-detail-label">Phone</span>
              <span class="contact-detail-value">01522 530048</span>
            </span>
          </a>
        </li>
      </ul>
    </div>

    <div class="contact-card" data-reveal data-reveal-delay="100ms">
      <form
        id="contact-form"
        class="contact-form"
        action="https://formspree.io/f/mvzjkzjb"
        method="POST"
      >
        <input type="hidden" name="_subject" value="New enquiry from azarfire.co.uk" />
        <!-- honeypot: hidden from people, catches bots -->
        <input type="text" name="_gotcha" class="contact-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <label class="field">
          <span class="field-label">Name</span>
          <input type="text" name="name" placeholder="Your name" autocomplete="name" required />
        </label>
        <label class="field">
          <span class="field-label">Email</span>
          <input type="email" name="email" placeholder="you@company.co.uk" autocomplete="email" required />
        </label>
        <label class="field">
          <span class="field-label">How can we help?</span>
          <textarea name="message" rows="4" placeholder="Tell us about your building or project…" required></textarea>
        </label>
        <button type="submit" class="btn btn-primary contact-submit">Send enquiry</button>
        <p class="contact-form-error" role="alert" hidden></p>
      </form>

      <div class="contact-success" role="status" hidden>
        <svg class="contact-success-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none">
          <circle cx="12" cy="12" r="11" fill="currentColor" opacity="0.15" />
          <path d="M7 12.5l3.2 3.2L17 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <h3 class="contact-success-title">Thanks &mdash; message sent.</h3>
        <p class="contact-success-text">
          We&rsquo;ve got your enquiry and we&rsquo;ll be in touch shortly. If it&rsquo;s urgent, call
          us on <a href="tel:+441522530048">01522 530048</a>.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  // Submit to Formspree in the background and show an inline thank-you.
  // Falls back to a normal form POST if JS is unavailable.
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  if (form) {
    const card = form.closest(".contact-card");
    const success = card?.querySelector(".contact-success") as HTMLElement | null;
    const errorEl = form.querySelector(".contact-form-error") as HTMLElement | null;
    const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (errorEl) errorEl.hidden = true;
      const label = submit?.textContent;
      if (submit) {
        submit.disabled = true;
        submit.textContent = "Sending…";
      }

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          form.hidden = true;
          if (success) {
            success.hidden = false;
            success.scrollIntoView({ behavior: "smooth", block: "nearest" });
          }
          return;
        }
        const data = await res.json().catch(() => null);
        throw new Error(data?.errors?.[0]?.message ?? "Request failed");
      } catch {
        if (errorEl) {
          errorEl.textContent =
            "Sorry, that didn't send. Please try again, or email info@azarfire.co.uk.";
          errorEl.hidden = false;
        }
      } finally {
        if (submit) {
          submit.disabled = false;
          submit.textContent = label ?? "Send enquiry";
        }
      }
    });
  }
</script>

<style>
  .contact {
    background-color: var(--color-white);
    padding-block: 6em;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4em;
    align-items: start;
  }

  .contact-label {
    font-size: 1.75em;
    margin-bottom: 0.15em;
  }
  .contact-heading {
    font-size: var(--fs-2xl);
    font-weight: 800;
    line-height: 1.08;
    color: var(--color-petrol);
    margin-bottom: 0.6em;
    max-width: 12em;
  }
  .contact-intro {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
    max-width: 32em;
    margin-bottom: 2em;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1em;
  }
  .contact-detail {
    display: inline-flex;
    align-items: center;
    gap: 1em;
  }
  .contact-detail-icon {
    display: grid;
    place-items: center;
    width: 3em;
    height: 3em;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-line);
    color: var(--color-petrol);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }
  .contact-detail-icon svg { width: 1.375em; height: 1.375em; }
  .contact-detail:hover .contact-detail-icon {
    background-color: var(--color-petrol);
    color: var(--color-mustard);
  }
  .contact-detail-text {
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }
  .contact-detail-label {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-grey-soft);
  }
  .contact-detail-value {
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--color-petrol);
  }

  /* Form card */
  .contact-card {
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 2.25em;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25em;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45em;
  }
  .field-label {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--color-charcoal);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.875em 1em;
    background-color: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    font-size: var(--fs-base);
    color: var(--color-charcoal);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    resize: vertical;
  }
  .field input::placeholder,
  .field textarea::placeholder { color: var(--color-grey-soft); }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-mustard);
    box-shadow: 0 0 0 3px rgba(217, 166, 41, 0.18);
  }
  .contact-submit {
    align-self: flex-start;
    margin-top: 0.25em;
  }

  /* Spam honeypot — off-screen for people, visible to bots */
  .contact-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .contact-form-error {
    margin-top: 0.25em;
    font-size: var(--fs-sm);
    color: #c0392b;
  }

  .contact-success {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5em;
  }
  .contact-success-icon {
    width: 2.5em;
    height: 2.5em;
    color: #2e7d32;
  }
  .contact-success-title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--color-petrol);
  }
  .contact-success-text {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: var(--color-grey);
  }
  .contact-success-text a {
    color: var(--color-petrol);
    text-decoration: underline;
    text-decoration-color: var(--color-mustard);
  }

  @media (max-width: 991px) {
    .contact { padding-block: 4.5em; }
    .contact-inner { grid-template-columns: 1fr; gap: 2.5em; }
    .contact-heading { font-size: 2.25em; max-width: none; }
  }

  @media (max-width: 767px) {
    .contact-heading { font-size: 2em; }
    .contact-card { padding: 1.5em; }
    .contact-submit { align-self: stretch; }
  }
</style>
