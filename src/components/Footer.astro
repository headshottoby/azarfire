---
import { Image } from "astro:assets";
import accreditations from "../assets/images/accreditations.png";

const siteLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/advice", label: "Advice" },
  { href: "/#contact", label: "Contact" },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <img
          src="/assets/images/logo-azar-inverted.png"
          alt="Azar Fire Ltd"
          width="220"
          height="55"
          class="footer-logo"
        />
        <p class="footer-tagline">
          We tell you straight whether your building&rsquo;s fire protection is doing its job.
          Certified work with full documentation.
        </p>
        <p class="footer-specialism">Passive fire protection specialists</p>
      </div>

      <nav class="footer-col" aria-label="Site">
        <p class="footer-col-title">Site</p>
        <ul>
          {siteLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="footer-col">
        <p class="footer-col-title">Get in touch</p>
        <ul>
          <li><a href="mailto:info@azarfire.co.uk">info@azarfire.co.uk</a></li>
          <li><span class="footer-muted">Nationwide UK support</span></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {year} Azar Fire Ltd. All rights reserved.</p>
      <div class="footer-accred" aria-label="Accreditations and certifications">
        <Image
          src={accreditations}
          alt="FIRAS UKAS Product Certification, IFSM Affiliate Member, and CHAS Accredited Contractor"
          widths={[600, 900, 1200]}
          sizes="(max-width: 767px) 80vw, 26em"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-petrol-deep);
    color: var(--color-white);
    padding-block: 4.5em 1.75em;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 3em;
    padding-bottom: 3em;
    border-bottom: 1px solid var(--color-line-light);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25em;
    max-width: 26em;
  }
  .footer-logo {
    width: 11em;
    height: auto;
  }
  .footer-tagline {
    font-size: var(--fs-base);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.7);
  }
  .footer-specialism {
    font-family: var(--font-script);
    font-size: 1.5em;
    color: var(--color-mustard);
    line-height: 1;
  }

  .footer-col-title {
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 1.25em;
  }
  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.875em;
  }
  .footer-col a {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.85);
    transition: color var(--transition-fast);
  }
  .footer-col a:hover { color: var(--color-mustard); }
  .footer-muted {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5em 2em;
    flex-wrap: wrap;
    padding-top: 1.75em;
  }
  .footer-copyright {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.5);
  }
  .footer-accred {
    background-color: var(--color-white);
    border-radius: var(--radius-pill);
    padding: 0.7em 1.4em;
    display: flex;
    align-items: center;
  }
  .footer-accred :global(img) {
    width: 26em;
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 991px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 2.5em;
    }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 767px) {
    .footer-top { grid-template-columns: 1fr; gap: 2em; }
    .footer-bottom { justify-content: center; text-align: center; }
    .footer-accred { width: 100%; justify-content: center; padding: 0.7em 1em; }
    .footer-accred :global(img) { width: 22em; }
  }
</style>
