---
const companyLinks = [
  { href: "/about", label: "About Us" },
  { href: "/services", label: "Services" },
  { href: "/team", label: "Our Team" },
];

const knowMoreLinks = [
  { href: "/support", label: "Support" },
  { href: "/privacy", label: "Privacy Policy" },
  { href: "/terms", label: "Terms & conditions" },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-row">
      <div class="footer-about">
        <div class="footer-logo-lockup">
          <img
            src="/assets/images/logo-azar-inverted.png"
            alt="Azar Fire"
            width="220"
            height="55"
            class="footer-logo"
          />
          <p class="footer-logo-sub">Nationwide fire safety</p>
        </div>
        <p class="footer-tagline">
          Nationwide fire safety consultancy and passive fire protection — keeping your buildings, your
          people and your compliance covered.
        </p>
      </div>

      <nav class="footer-nav" aria-label="Company">
        <p class="footer-nav-title">Company</p>
        <ul>
          {companyLinks.map((link) => (
            <li><a href={link.href} data-underline-link>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav class="footer-nav" aria-label="Know More">
        <p class="footer-nav-title">Know More</p>
        <ul>
          {knowMoreLinks.map((link) => (
            <li><a href={link.href} data-underline-link>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <hr class="footer-divider" />

    <p class="footer-copyright">© {year} Azar Fire Ltd. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-petrol);
    color: var(--color-white);
    padding-block: 6.25em 1.25em;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 4em;
    align-items: center;
  }

  .footer-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 6em;
    width: 100%;
    align-items: flex-start;
  }

  .footer-about {
    display: flex;
    flex-direction: column;
    gap: 1.25em;
    max-width: 22.25em;
  }

  .footer-logo-lockup {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .footer-logo {
    width: 13.75em;
    height: auto;
  }

  .footer-logo-sub {
    font-family: var(--font-accent);
    font-weight: 600;
    font-size: var(--fs-sm);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-mustard);
    line-height: 1;
  }

  .footer-tagline {
    font-family: var(--font-accent);
    font-weight: 400;
    font-size: var(--fs-sm);
    line-height: 1.6;
    color: var(--color-white);
  }

  .footer-nav-title {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: var(--fs-md);
    color: var(--color-white);
    margin-bottom: 1.5em;
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .footer-nav a {
    position: relative;
    display: inline-block;
    font-family: var(--font-accent);
    font-weight: 500;
    font-size: var(--fs-sm);
    color: var(--color-white);
    opacity: 0.85;
    text-decoration: none;
    transition: opacity var(--transition-fast), color var(--transition-fast);
  }

  .footer-nav a:hover {
    opacity: 1;
    color: var(--color-mustard);
  }

  /* Underline sweep — pure CSS scaleX transition */
  .footer-nav a[data-underline-link]::before {
    content: "";
    position: absolute;
    bottom: -0.25em;
    left: 0;
    width: 100%;
    height: 0.0625em;
    background-color: currentColor;
    transform: scaleX(0) rotate(0.001deg);
    transform-origin: right;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0, 1);
  }

  @media (hover: hover) and (pointer: fine) {
    .footer-nav a[data-underline-link]:hover::before {
      transform: scaleX(1) rotate(0.001deg);
      transform-origin: left;
    }
  }

  .footer-nav a[data-underline-link]:focus-visible {
    outline: 0.125rem solid var(--color-mustard);
    outline-offset: 0.25rem;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-nav a[data-underline-link]::before {
      transition: none;
    }
  }

  .footer-divider {
    width: 100%;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer-copyright {
    font-family: var(--font-accent);
    font-size: var(--fs-sm);
    color: var(--color-white);
    opacity: 0.85;
    text-align: center;
    line-height: 1.2;
  }

  @media (max-width: 991px) {
    .footer-row {
      grid-template-columns: 1fr 1fr;
      gap: 3em;
    }
    .footer-about {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767px) {
    .footer-row {
      grid-template-columns: 1fr;
      gap: 2em;
    }
    .footer {
      padding-block: 3em 1em;
    }
  }
</style>
