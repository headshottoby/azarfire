---
const reasons = [
  {
    title: "We won't sell you work you don't need",
    body: "If your building is already compliant, we'll tell you. If it's not, we'll tell you that too — and explain exactly why.",
  },
  {
    title: "We know the rules so you don't have to",
    body: "Fire safety legislation has tightened significantly in recent years. We stay on top of the changes so you're always covered.",
  },
  {
    title: "We get on with it",
    body: "No fuss, minimal disruption. We plan every job to work around your building and the people in it.",
  },
  {
    title: "One team, start to finish",
    body: "You deal with us — not a chain of subcontractors. Same standards, same contact, every time.",
  },
];
---

<section class="why-azar" aria-labelledby="why-heading">
  <div class="container why-azar-inner">
    <header class="why-azar-header" data-reveal>
      <h2 id="why-heading" class="why-azar-heading">Why Azar Fire?</h2>
      <p class="why-azar-sub">Why people work with us</p>
    </header>

    <div class="why-azar-body">
      <ul class="why-azar-reasons" data-reveal-stagger>
        {
          reasons.map((reason) => (
            <li class="why-azar-reason">
              <h3 class="why-azar-reason-title">{reason.title}</h3>
              <p class="why-azar-reason-body">{reason.body}</p>
            </li>
          ))
        }
      </ul>

      <div class="why-azar-media" aria-hidden="true">
        <div class="why-azar-media-back"></div>
        <div class="why-azar-media-front">
          <span>Image to be supplied</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-azar {
    background-color: var(--color-petrol);
    color: var(--color-white);
    padding-block: 6.5em 5em;
  }

  .why-azar-header {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    margin-bottom: 3em;
  }

  .why-azar-heading {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--fs-xl); /* 36px */
    color: var(--color-mustard);
    line-height: 1.2;
  }

  .why-azar-sub {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--fs-md); /* 20px */
    color: var(--color-white);
  }

  .why-azar-body {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 24.375em; /* 390px */
    gap: 4em;
    align-items: start;
    padding: 3em 3em 3em 0;
  }

  .why-azar-body::before {
    content: "";
    position: absolute;
    inset: 0 18em 0 -3em;
    background-color: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-lg);
    z-index: 0;
  }

  .why-azar-reasons {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3em 3em;
    list-style: none;
    padding: 0;
    margin: 0;
    padding-left: 3em;
  }

  .why-azar-reason {
    display: flex;
    flex-direction: column;
    gap: 1.25em;
    max-width: 23.25em; /* 372px */
  }

  .why-azar-reason-title {
    font-family: var(--font-accent);
    font-weight: 600;
    font-size: var(--fs-lg); /* 24px */
    line-height: 1.2;
    color: var(--color-mustard);
  }

  .why-azar-reason-body {
    font-family: var(--font-heading);
    font-size: var(--fs-md); /* 20px */
    color: var(--color-white);
    line-height: 1.4;
  }

  /* Stacked rectangles on the right (mustard back, warm-white front offset) */
  .why-azar-media {
    position: relative;
    width: 100%;
    aspect-ratio: 390 / 430;
    z-index: 1;
  }

  .why-azar-media-back,
  .why-azar-media-front {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-md);
  }

  .why-azar-media-back {
    background-color: var(--color-mustard);
    top: 0;
    left: 0;
  }

  .why-azar-media-front {
    background-color: var(--color-warm-white);
    top: 0.625em; /* 10px down */
    left: -0.5625em; /* 9px left */
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-grey-soft);
    font-family: var(--font-heading);
    font-size: 0.875em;
  }

  @media (max-width: 1199px) {
    .why-azar-body {
      grid-template-columns: minmax(0, 1fr) 18em;
      gap: 3em;
    }
    .why-azar-body::before {
      inset: 0 13em 0 -2em;
    }
  }

  @media (max-width: 991px) {
    .why-azar-body {
      grid-template-columns: 1fr;
      gap: 3em;
      padding: 2em 0;
    }
    .why-azar-body::before {
      inset: 0;
    }
    .why-azar-reasons {
      padding-left: 1.5em;
      padding-right: 1.5em;
    }
    .why-azar-media {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .why-azar-heading {
      font-size: 1.875em;
    }
    .why-azar-reasons {
      grid-template-columns: 1fr;
      gap: 2em;
    }
  }
</style>
